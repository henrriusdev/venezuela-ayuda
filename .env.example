# ---- Supabase (required for data) -----------------------------------------
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable client key (new `sb_publishable_...` format). Safe for the browser.
# This alone is enough to run: RLS allows inserts and reads go through the
# public_* views that omit phone numbers.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy name still supported as a fallback:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret key — SERVER ONLY, never expose to the client. RECOMMENDED for
# production: writes bypass RLS so only your server can write (better abuse
# control). New `sb_secret_...` format; legacy SUPABASE_SERVICE_ROLE_KEY also works.
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ------------------------------------------------------------------
# Public base URL, used for share links and SEO. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://venezuelaayuda.com

# ---- Maps (optional) -------------------------------------------------------
# Defaults to keyless OpenStreetMap raster tiles. For production scale, set a
# vector/raster style URL from a provider with an SLA (e.g. MapTiler):
# https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
NEXT_PUBLIC_MAP_STYLE_URL=

# ---- Dedupe review API (required for /deduplicar) --------------------------
# Base URL of the deduplication API (FastAPI/Swagger). No trailing slash.
# The review console calls this directly from the browser.
NEXT_PUBLIC_DEDUPE_API_URL=https://venezuela-terremoto-c4gafbfpc0dadpcj.eastus-01.azurewebsites.net
#
# The /deduplicar console also needs server-side setup (no extra env var):
#   1. Apply migration supabase/migrations/202606280002_dedupe_reviewers_and_locks.sql
#      (creates the reviewer allowlist + per-group locks). See README → "Consola
#      de deduplicación (/deduplicar)".
#   2. Add your email to the `reviewer_emails` table, then sign up at /deduplicar
#      to set a password (same flow as /admin). Reviewers without an allowlist
#      row are rejected after login.
# Reviews go through SUPABASE_SECRET_KEY (server-only), so that key is required
# for /deduplicar to work — the publishable key alone is not enough here.

# ---- AI classification (optional) -----------------------------------------
# Without a key, /api/classify uses a built-in Spanish keyword classifier.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Face recognition / FR-API (optional) ---------------------------------
# Anti-duplicate at registration + admin tools (search, dedup, cross-base
# reconciliation). Server-side only; the key never reaches the browser.
# Without FR_API_KEY the site works the same — face checks are simply skipped.
# Base URL already has a sensible default; only the key is required to enable it.
FR_API_URL=https://fr-api.reportavnzla.com:8443
FR_API_KEY=
# ---- Observability / logging (optional) ------------------------------------
# Client-side error reporting. When "true", the error boundary (src/app/error.tsx)
# POSTs caught render errors (message + digest only, no PII) to /api/client-error
# so they land in the server logs. OFF by default. Must be NEXT_PUBLIC because the
# error boundary is a client component; the API route honors the same flag.
NEXT_PUBLIC_CLIENT_ERROR_LOGGING=

# Verbose server diagnostics. When LOG_LEVEL=debug (or DEBUG is truthy), logDebug()
# calls emit; otherwise they are a no-op. Server-side error/warn/info always log.
# LOG_LEVEL=debug

# ---- External Sources (optional) -------------------------------------------
# URLs for external datasets used in the search page.
# If omitted, they fall back to the public endpoints.
HOSPITAL_REGISTRY_CSV_URL=https://docs.google.com/spreadsheets/d/1fRQ3zEkIFMV2SYEjQiCuwewKAJDSixRepzBUf3ZFqf4/gviz/tq?tqx=out:csv&gid=963077964
MISSING_PERSONS_API_URL=https://desaparecidos-terremoto-api.theempire.tech/api/personas
MISSING_PERSONS_SOURCE_URL=https://desaparecidosterremotovenezuela.com
